class Node:
	def __init__(self, data):
		self.data = data
		self.left = None
		self.right = None
def a(r):
	if r is None:
		return 
	if (r.left and not r.right) or (r.right and not r.left):
		print(r.data)
	a(r.left)
	a(r.right)
if __name__=="__main__":
    r=Node(1)
    r.left=Node(2)
    r.right=Node(3)
    r.left.left=Node(4)
    r.left.right=Node(5)
    r.right.right=Node(6)
    a(r)
    
